{% from "_/panel/base.macros.j2" import field_header, field_label %}

{% macro side_panel(is_visible = "@IsVisible", margin_right = "160", vertical_alignment = "Top") -%}
    <Widget
        DataSource="{LibraryPanel}"
        IsVisible="{{ is_visible }}"
        WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
        HorizontalAlignment="Center" VerticalAlignment="{{ vertical_alignment }}"
        MarginRight="{{ margin_right }}">
        <Children>
            {{ caller() }}
        </Children>
    </Widget>
{%- endmacro %}

{% macro action_button(text, command, tooltip, brush = "Popup.Done.Button", width = "240", height = "60", is_enabled = "@IsEnabled") -%}
    <Widget
        WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
        HorizontalAlignment="Center" VerticalAlignment="Bottom">
        <Children>
            <HintWidget
                DataSource="{{ tooltip }}"
                Command.HoverBegin="ExecuteBeginHint" Command.HoverEnd="ExecuteEndHint"/>
            <ButtonWidget
                DoNotPassEventsToChildren="true"
                WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                SuggestedWidth="{{ width }}" SuggestedHeight="{{ height }}"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Brush="{{ brush }}"
                IsEnabled="{{ is_enabled }}"
                Command.Click="{{ command }}">
                <Children>
                    <TextWidget
                        WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Brush="Clan.Name.Tuple"
                        Brush.FontSize="24"
                        Text="{{ text }}"
                        TextAlignment="Center" />
                    <HintWidget
                        DataSource="{{ tooltip }}"
                        Command.HoverBegin="ExecuteBeginHint" Command.HoverEnd="ExecuteEndHint"/>
                </Children>
            </ButtonWidget>
        </Children>
    </Widget>
{%- endmacro %}

<ListPanel
    DataSource="{LibraryPanel}"
    IsVisible="@ShowEmptyText"
    MarginRight="160"
    WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
    HorizontalAlignment="Center" VerticalAlignment="Center"
    StackLayout.LayoutMethod="VerticalBottomToTop">
    <Children>
        <ListPanel
            WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            StackLayout.LayoutMethod="VerticalBottomToTop">
            <Children>
                <TextWidget
                    WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Brush="Kingdom.DecisionParagraph.Text"
                    Brush.FontSize="20"
                    MaxWidth="720"
                    Text="@ExportsEmptyText"
                    TextAlignment="Center"
                    MarginBottom="12" />
                <TextWidget
                    WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Brush="Kingdom.DecisionParagraph.Text"
                    Brush.FontSize="20"
                    MaxWidth="720"
                    Text="@ExportsHintText"
                    TextAlignment="Center"
                    MarginBottom="12" />
            </Children>
        </ListPanel>
    </Children>
</ListPanel>

{% call side_panel("@IsVisible", "160", "Top") %}

        <ListPanel
            WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            IsVisible="@HasSelection"
            StackLayout.LayoutMethod="VerticalBottomToTop">
            <Children>

                {# Faction (single) #}
                {{ field_header("@NameHeader") }}

                <ListPanel
                    WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    StackLayout.LayoutMethod="HorizontalLeftToRight"
                    MarginBottom="12">
                    <Children>
                        {{ field_label("@Name") }}
                    </Children>
                </ListPanel>

                {# Troop (single) #}
                {{ field_header("@TargetHeader", "@IsTroop") }}

                <ListPanel
                    IsVisible="@IsTroop"
                    WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    StackLayout.LayoutMethod="HorizontalLeftToRight"
                    MarginBottom="12">
                    <Children>
                        {{ field_label("@TargetName") }}
                    </Children>
                </ListPanel>

                {# File #}
                {{ field_header("@ExportFileHeader") }}

                <TextWidget
                    WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Brush="Kingdom.DecisionParagraph.Text"
                    Brush.FontSize="18"
                    MaxWidth="720"
                    Text="@ExportPath"
                    TextAlignment="Center"
                    MarginBottom="12" />

                {# Contents (faction) #}
                {{ field_header("@ContentsHeader", "@IsFaction") }}

                <ListPanel
                    IsVisible="@IsFaction"
                    DataSource="{TroopNames}"
                    WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                    StackLayout.LayoutMethod="VerticalBottomToTop"
                    HorizontalAlignment="Center"
                    MarginBottom="12">
                    <ItemTemplate>
                        <TextWidget
                            WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Brush="Clan.Name.Tuple"
                            Brush.FontSize="20"
                            Text="@Name"
                            TextAlignment="Center"
                            MarginBottom="4" />
                    </ItemTemplate>
                </ListPanel>

            </Children>
        </ListPanel>

{% endcall %}


{% call side_panel("@IsVisible", "160", "Bottom") %}

        <ListPanel
            WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            IsVisible="@HasSelection"
            StackLayout.LayoutMethod="VerticalBottomToTop">
            <Children>

                {# Import Button #}
                {{ action_button("@ImportButtonText", "ExecuteImport", "{ImportTooltip}", "Popup.Done.Button", "240", "60", "@CanImport") }}

                {# Export NPCCharacters #}
                {{ action_button("@ExportNpcCharactersButtonText", "ExecuteExportNpcCharacters", "{ExportNpcCharactersTooltip}", "Popup.Done.Button", "240", "60", "@CanExportNpcCharacters") }}

                {# Edit Button #}
                {{ action_button("@EditButtonText", "ExecuteEdit", "{EditTooltip}", "Popup.Cancel.Button", "240", "60") }}

                {# Delete Button #}
                {{ action_button("@DeleteButtonText", "ExecuteDelete", "{DeleteTooltip}", "Popup.Delete.Button", "240", "60") }}

            </Children>
        </ListPanel>

{% endcall %}
