{% from "_/macros.panel.j2" import panel_header, panel_label %}
{% from "_/macros.buttons.j2" import button_text %}

{# ---------------------------------------------- #}
{# Library panel helpers                          #}
{# ---------------------------------------------- #}

{% macro side_panel(margin_right="160", vertical_alignment="Top") %}
    <Widget
        IsVisible="@OnLibraryPage"
        WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
        HorizontalAlignment="Center" VerticalAlignment="{{ vertical_alignment }}"
        MarginRight="{{ margin_right }}">
        <Children>
            {{ caller() }}
        </Children>
    </Widget>
{% endmacro %}

{# ---------------------------------------------- #}
{# Empty state                                    #}
{# ---------------------------------------------- #}

<ListPanel
    IsVisible="@ShowEmptyText"
    MarginRight="160"
    WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
    HorizontalAlignment="Center" VerticalAlignment="Center"
    StackLayout.LayoutMethod="VerticalBottomToTop">
    <Children>

        <ListPanel
            WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            StackLayout.LayoutMethod="VerticalBottomToTop">
            <Children>

                <TextWidget
                    WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Brush="Kingdom.DecisionParagraph.Text"
                    Brush.FontSize="20"
                    MaxWidth="720"
                    Text="@ExportsEmptyText"
                    TextAlignment="Center"
                    MarginBottom="12" />

                <TextWidget
                    WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Brush="Kingdom.DecisionParagraph.Text"
                    Brush.FontSize="20"
                    MaxWidth="720"
                    Text="@ExportsHintText"
                    TextAlignment="Center"
                    MarginBottom="12" />

            </Children>
        </ListPanel>

    </Children>
</ListPanel>

{# ---------------------------------------------- #}
{# Selection details (top)                        #}
{# ---------------------------------------------- #}

{% call side_panel("160", "Top") %}

    <ListPanel
        WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
        HorizontalAlignment="Center" VerticalAlignment="Center"
        IsVisible="@HasSelection"
        StackLayout.LayoutMethod="VerticalBottomToTop">
        <Children>

            {# ------------------------------------------ #}
            {# Faction (single)                           #}
            {# ------------------------------------------ #}

            {{ panel_header("@NameHeader") }}

            <ListPanel
                WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                StackLayout.LayoutMethod="HorizontalLeftToRight"
                MarginBottom="12">
                <Children>
                    {{ panel_label("@Name") }}
                </Children>
            </ListPanel>

            {# ------------------------------------------ #}
            {# File                                       #}
            {# ------------------------------------------ #}

            {{ panel_header("@ExportFileHeader") }}

            <TextWidget
                WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Brush="Kingdom.DecisionParagraph.Text"
                Brush.FontSize="18"
                MaxWidth="720"
                Text="@ExportPath"
                TextAlignment="Center"
                MarginBottom="12" />

            {# ------------------------------------------ #}
            {# Contents (faction)                         #}
            {# ------------------------------------------ #}

            {{ panel_header("@ContentsHeader", "@IsFaction") }}

            <ListPanel
                IsVisible="@IsFaction"
                DataSource="{TroopNames}"
                WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                StackLayout.LayoutMethod="VerticalBottomToTop"
                HorizontalAlignment="Center"
                MarginBottom="12">
                <ItemTemplate>
                    <TextWidget
                        WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Brush="Clan.Name.Tuple"
                        Brush.FontSize="20"
                        Text="@Name"
                        TextAlignment="Center"
                        MarginBottom="4" />
                </ItemTemplate>
            </ListPanel>

        </Children>
    </ListPanel>

{% endcall %}

{# ---------------------------------------------- #}
{# Action buttons (bottom)                        #}
{# ---------------------------------------------- #}

{% call side_panel("160", "Bottom") %}

    <ListPanel
        WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
        HorizontalAlignment="Center" VerticalAlignment="Center"
        IsVisible="@HasSelection"
        StackLayout.LayoutMethod="VerticalBottomToTop">
        <Children>

            {{ button_text("{ImportButton}", "Popup.Done.Button", 240, 60) }}

            {{ button_text("{ConvertButton}", "Popup.Done.Button", 240, 60) }}

            {{ button_text("{EditButton}", "Popup.Cancel.Button", 240, 60) }}

            {{ button_text("{DeleteButton}", "Popup.Delete.Button", 240, 60) }}

        </Children>
    </ListPanel>

{% endcall %}
