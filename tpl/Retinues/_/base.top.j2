{% from "_/macros.buttons.j2" import button_text %}

{# ---------------------------------------------- #}
{# Top panel                                      #}
{# ---------------------------------------------- #}

<Widget
    Id="TopPanel"
    DataSource="{TopPanel}"
    VisualDefinition="TopPanel"
    WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
    SuggestedHeight="196"
    PositionYOffset="-196"
    Sprite="StdAssets\top_header"
    Color="@FactionColor"
    IsVisible="true"
    ZOrder="9999">
    <Children>

        <Widget
            WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
            MarginBottom="35">
            <Children>

                {# ------------------------------------------ #}
                {# Macros                                     #}
                {# ------------------------------------------ #}

                {# Banner button (culture / clan) #}
                {% macro banner(command, banner, hint, text, offset, text_offset, alignment, is_enabled="true", is_visible="true") %}
                    <ButtonWidget
                        DoNotPassEventsToChildren="true"
                        WidthSizePolicy="CoverChildren" HeightSizePolicy="Fixed"
                        SuggestedHeight="180"
                        HorizontalAlignment="{{ alignment }}" VerticalAlignment="Top"
                        PositionXOffset="{{ offset }}" PositionYOffset="-8"
                        Command.Click="{{ command }}"
                        IsEnabled="{{ is_enabled }}"
                        IsVisible="{{ is_visible }}"
                        UpdateChildrenStates="true"
                        GamepadNavigationIndex="0">
                        <Children>

                            <MaskedTextureWidget
                                DataSource="{{ banner }}"
                                WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                                SuggestedWidth="105" SuggestedHeight="126"
                                HorizontalAlignment="{{ alignment }}" VerticalAlignment="Center"
                                Brush="Clan.TornBanner"
                                {% if version == "13" -%}
                                    AdditionalArgs="@AdditionalArgs" ImageId="@Id" TextureProviderName="@TextureProviderName"
                                {%- else -%}
                                    AdditionalArgs="@AdditionalArgs" ImageId="@Id" ImageTypeCode="@ImageTypeCode"
                                {%- endif -%}
                            />

                            <HintWidget
                                DataSource="{{ hint }}"
                                Command.HoverBegin="ExecuteBeginHint"
                                Command.HoverEnd="ExecuteEndHint" />

                            <TextWidget
                                WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                HorizontalAlignment="{{ alignment }}" VerticalAlignment="Center"
                                PositionXOffset="{{ text_offset }}"
                                Brush="Kingdom.NameTitle.Text"
                                Text="{{ text }}"
                                TextAlignment="{{ alignment }}" />

                        </Children>
                    </ButtonWidget>
                {% endmacro %}

                {# Tab control button (ClanScreen style) #}
                {% macro tab_button(brush, cmd, selected, text, visible="true", sug_w="!Header.Tab.Center.Width.Scaled", sug_h="!Header.Tab.Center.Height.Scaled", pos_xoff="0", pos_yoff="0", text_xoff="0", text_mt="0") %}
                    <ButtonWidget
                        DoNotPassEventsToChildren="true"
                        WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                        SuggestedWidth="{{ sug_w }}"
                        SuggestedHeight="{{ sug_h }}"
                        PositionXOffset="{{ pos_xoff }}"
                        PositionYOffset="{{ pos_yoff }}"
                        Brush="{{ brush }}"
                        Command.Click="{{ cmd }}"
                        IsSelected="{{ selected }}"
                        IsVisible="{{ visible }}"
                        UpdateChildrenStates="true">
                        <Children>

                            <TextWidget
                                WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                Brush="Clan.TabControl.Text"
                                PositionXOffset="{{ text_xoff }}"
                                MarginTop="{{ text_mt }}"
                                Text="{{ text }}" />

                        </Children>
                    </ButtonWidget>
                {% endmacro %}

                {# ------------------------------------------ #}
                {# Banners                                    #}
                {# ------------------------------------------ #}

                {# Culture banner #}
                {{ banner("ExecuteSelectLeftBanner", "{LeftBanner}", "{LeftBannerHint}", "@LeftBannerName", "20", "120", "Left", is_enabled="@CanSelectLeftBanner", is_visible="@IsLeftBannerVisible") }}

                {# Clan banner #}
                {{ banner("ExecuteSelectRightBanner", "{RightBanner}", "{RightBannerHint}", "@RightBannerName", "-20", "-120", "Right", is_enabled="@CanSelectRightBanner", is_visible="@IsRightBannerVisible") }}

                {# ------------------------------------------ #}
                {# Name panel                                 #}
                {# ------------------------------------------ #}

                <Widget
                    WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                    SuggestedWidth="887" SuggestedHeight="180"
                    HorizontalAlignment="Center" VerticalAlignment="Top"
                    Sprite="StdAssets\tabbar_long">
                    <Children>

                        <Widget
                            WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                            HorizontalAlignment="Center" VerticalAlignment="Top"
                            MarginTop="12">
                            <Children>

                                <Widget
                                    DoNotPassEventsToChildren="false"
                                    WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                                    SuggestedWidth="440" SuggestedHeight="47"
                                    Brush="Kingdom.Name.Edit.Button"
                                    UpdateChildrenStates="true"
                                    HorizontalAlignment="Center"
                                    GamepadNavigationIndex="2">
                                    <Children>

                                        <ListPanel
                                            WidthSizePolicy="CoverChildren" HeightSizePolicy="StretchToParent"
                                            StackLayout.LayoutMethod="HorizontalLeftToRight"
                                            HorizontalAlignment="Center"
                                            UpdateChildrenStates="true">
                                            <Children>

                                                <TextWidget
                                                    Brush.FontColor="#cfc1a1ff"
                                                    WidthSizePolicy="CoverChildren" HeightSizePolicy="StretchToParent"
                                                    Brush.FontSize="60"
                                                    Text="@EditorTitle" />

                                            </Children>
                                        </ListPanel>

                                    </Children>
                                </Widget>
                            </Children>
                        </Widget>

                    </Children>
                </Widget>

                {# Reset button #}
                <Widget
                    WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    MarginLeft="380">
                    <Children>

                        {{ button_text("{ResetButton}", "Popup.Delete.Button", "200", "60") }}

                    </Children>
                </Widget>

                {# Export button #}
                <Widget
                    WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    MarginRight="380">
                    <Children>

                        {{ button_text("{ExportButton}", "Popup.Done.Button", "200", "60") }}

                    </Children>
                </Widget>

                {# ------------------------------------------ #}
                {# Tab control (ClanScreen style)             #}
                {# ------------------------------------------ #}

                <ListPanel
                    WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                    HorizontalAlignment="Center" VerticalAlignment="Bottom"
                    MarginBottom="3">
                    <Children>

                        {# Editor tab #}
                        {{ tab_button("Header.Tab.Left", "ExecuteSelectEditorTab", "@IsEditorTabSelected", "@EditorTabText", sug_w="!Header.Tab.Left.Width.Scaled", sug_h="!Header.Tab.Left.Height.Scaled", text_xoff="10", text_mt="3") }}

                        {# Doctrines tab #}
                        {{ tab_button("Header.Tab.Center", "ExecuteSelectDoctrinesTab", "@IsDoctrinesTabSelected", "@DoctrinesTabText", visible="@IsDoctrinesTabVisible", pos_yoff="6") }}

                        {# Library tab #}
                        {{ tab_button("Header.Tab.Center", "ExecuteSelectLibraryTab", "@IsLibraryTabSelected", "@LibraryTabText", pos_yoff="6") }}

                        {# Settings tab #}
                        {{ tab_button("Header.Tab.Right", "ExecuteSelectSettingsTab", "@IsSettingsTabSelected", "@SettingsTabText", sug_w="!Header.Tab.Right.Width.Scaled", sug_h="!Header.Tab.Right.Height.Scaled", text_xoff="-10", text_mt="3") }}

                    </Children>
                </ListPanel>

            </Children>
        </Widget>

    </Children>
</Widget>
