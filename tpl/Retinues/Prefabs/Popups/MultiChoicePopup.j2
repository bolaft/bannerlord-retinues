<Prefab>
    <Window>

        <!-- Multi-Choice Popup: supports 3 or more labeled buttons -->
        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                Sprite="BlankWhiteSquare_9" Color="#000000ff" AlphaFactor="0.7">
            <Children>

                {#
                    DimensionSyncWidget syncs its own height from PopupContentList.
                    This gives StretchToParent children (canvas clip, gradient, frame) a
                    well-defined height, avoiding the CoverChildren + StretchToParent deadlock
                    that caused the frame to stretch to the full screen.
                #}
                <DimensionSyncWidget Id="PopupContainer"
                        WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="640"
                        HorizontalAlignment="Center" VerticalAlignment="Center" PositionYOffset="-50"
                        DimensionToSync="Vertical" WidgetToCopyHeightFrom="PopupContentList">
                    <Children>

                        <!-- Canvas background clipped to container height so it never drives size -->
                        <Widget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent"
                                SuggestedWidth="640" ClipContents="true">
                            <Children>
                                <Widget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent"
                                        SuggestedWidth="640"
                                        HorizontalAlignment="Center" VerticalAlignment="Top"
                                        Sprite="StdAssets\Popup\canvas"/>
                            </Children>
                        </Widget>

                        <!-- Content list - drives container height via DimensionSyncWidget -->
                        <ListPanel Id="PopupContentList"
                                   WidthSizePolicy="Fixed" HeightSizePolicy="CoverChildren"
                                   SuggestedWidth="640"
                                   StackLayout.LayoutMethod="VerticalBottomToTop">
                            <Children>

                                <!-- Title -->
                                <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                           StackLayout.LayoutMethod="VerticalBottomToTop">
                                    <Children>
                                        <AutoHideRichTextWidget
                                            WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                            MarginLeft="30" MarginRight="30" MarginTop="10" MinHeight="50"
                                            Brush="Popup.Title.Text" Text="@TitleText"
                                            WidgetToHideIfEmpty="..\TitleDivider"/>
                                        <Widget Id="TitleDivider"
                                                WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                                                SuggestedHeight="23" Sprite="StdAssets\Popup\divider"/>
                                    </Children>
                                </ListPanel>

                                <!-- Description (auto-hides itself when empty) -->
                                <AutoHideRichTextWidget
                                    WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                    MarginLeft="30" MarginRight="30" MarginTop="20" MarginBottom="20"
                                    Brush="Popup.Description.Text" MinHeight="10"
                                    Text="@DescriptionText"/>

                                <!-- Divider above buttons -->
                                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                                        SuggestedHeight="23" Sprite="StdAssets\Popup\divider"/>

                                <!-- Dynamic button row, one item per choice -->
                                <ListPanel DataSource="{Buttons}"
                                           WidthSizePolicy="CoverChildren" SuggestedHeight="80"
                                           HorizontalAlignment="Center"
                                           MarginTop="10" MarginBottom="10"
                                           StackLayout.LayoutMethod="HorizontalLeftToRight">
                                    <ItemTemplate>
                                        <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                                                SuggestedWidth="180" SuggestedHeight="64"
                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                MarginLeft="8" MarginRight="8">
                                            <Children>
                                                <ButtonWidget
                                                    DoNotPassEventsToChildren="true"
                                                    WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                                    Brush="Popup.Done.Button"
                                                    Command.Click="ExecuteAction">
                                                    <Children>
                                                        <TextWidget
                                                            WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                                                            SuggestedHeight="35" VerticalAlignment="Center"
                                                            MarginLeft="10" MarginRight="10"
                                                            Brush="Popup.Button.Text" Text="@Label"/>
                                                    </Children>
                                                </ButtonWidget>
                                            </Children>
                                        </Widget>
                                    </ItemTemplate>
                                </ListPanel>

                            </Children>
                        </ListPanel>

                        <!-- Gradient overlay (StretchToParent of DimensionSyncWidget - safe) -->
                        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                Sprite="StdAssets\Popup\canvas_gradient" IsEnabled="false"/>

                        <!-- Frame border (StretchToParent of DimensionSyncWidget - safe) -->
                        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                Sprite="frame_9"
                                ExtendLeft="18" ExtendTop="18" ExtendRight="18" ExtendBottom="18"
                                IsEnabled="false"/>

                    </Children>
                </DimensionSyncWidget>

            </Children>
        </Widget>

    </Window>
</Prefab>
